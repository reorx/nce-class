# server 环境变量（docker compose 的 env_file）。真值在服务器 /opt/apps/nce-class/.env
# 手填，绝不入库。本文件是变量名 SSOT（deploy 工作区文档依赖它做核对）。

# 会话签名密钥，生产必填（缺失时 server 拒绝启动）。生成：openssl rand -hex 32
AUTH_SECRET=

# 微信小程序 code2session 凭据（mp 后台获取）。本地开发不需要：dev 脚本自带 WX_MOCK=1
WX_APPID=
WX_SECRET=

# 存储层默认 local（server/data/uploads）。接对象存储时启用：
# S3_VENDOR=minio|oss
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_CUSTOM_DOMAIN=
